# ── Runtime Secrets ────────────────────────────────────────────────────
# Server-side only — NEVER prefix with NEXT_PUBLIC_
OPENAI_API_KEY=sk-proj-...

# ElevenLabs text-to-speech
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Telnyx SMS + Voice + Calls
TELNYX_API_KEY=KEY...
TELNYX_PUBLIC_KEY=...
TELNYX_FROM_NUMBER=+1XXXXXXXXXX
TELNYX_MESSAGING_PROFILE_ID=...
TELNYX_CONNECTION_ID=...

# Cloudflare
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_ZONE_ID=...

# ── Public Config ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Donk AI
NEXT_PUBLIC_APP_URL=https://donk.unykorn.org
NEXT_PUBLIC_BRAND_PARENT=Unykorn
NEXT_PUBLIC_BRAND_URL=https://unykorn.org

# ── Rate Limiting ───────────────────────────────────────────────────────
# Upstash Redis for distributed rate limiting (production)
# Create free at: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Per-route limits (requests per minute) — used in dev fallback + Redis
RATE_LIMIT_CHAT_RPM=20
RATE_LIMIT_TTS_RPM=10
RATE_LIMIT_SMS_RPM=5
